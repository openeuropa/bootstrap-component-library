    "@storybook/addon-webpack5-compiler-babel": "^4.0.1",
    "@storybook/builder-webpack5": "^10.4.0",
    "@storybook/html": "^10.4.0",
    "@testing-library/dom": "^10.4.1",
    "@types/react": "^19.2.14",
